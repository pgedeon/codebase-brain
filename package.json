{
  "name": "codebase-brain",
  "version": "0.1.0",
  "description": "OpenClaw Codebase Digital Twin Plugin - Index and navigate codebases with structured tools",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "index": "node src/cli/index.js",
    "query": "node src/cli/query.js",
    "dev": "node --watch src/cli/index.js"
  },
  "keywords": ["openclaw", "plugin", "codebase", "indexing", "tree-sitter"],
  "author": "OpenClaw Community",
  "license": "MIT",
  "openclaw": {
    "extensions": ["./src/plugin.ts"]
  },
  "peerDependencies": {
    "openclaw": "^2026.3.0"
  },
  "dependencies": {
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-typescript": "^0.21.2",
    "tree-sitter-python": "^0.21.0",
    "better-sqlite3": "^9.4.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0"
  }
}

